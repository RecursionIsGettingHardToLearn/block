# Estándares generales del repositorio.
# Cualquier editor moderno los aplica automáticamente.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2
max_line_length = 120

[*.{ts,tsx,js,jsx,mjs,cjs,json,jsonc,css,html,yml,yaml}]
indent_size = 2

[*.py]
indent_size = 4

[*.md]
# En Markdown, dos espacios al final fuerzan un salto de línea: no se recortan.
trim_trailing_whitespace = false

[*.{sh,sql}]
indent_size = 2

[Makefile]
indent_style = tab
