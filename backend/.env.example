# ─── Base de datos ──────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=cambiar-esta-clave
DB_NAME=evoting
# Ponerlo en 'true' solo con Postgres gestionado (Azure Database for PostgreSQL,
# RDS, etc.), que exigen TLS. Con Postgres en un contenedor local: false.
DB_SSL=false

# ─── Autenticación ──────────────────────────────────────────────────────────
# Generar con: openssl rand -base64 48
JWT_SECRET=cambiar-por-un-secreto-largo-y-aleatorio
JWT_EXPIRES_IN=8h

# ─── Servidor ───────────────────────────────────────────────────────────────
PORT=3000
# Origen del frontend, para CORS. En producción, tras el proxy inverso, el
# frontend y la API comparten origen y esto queda como respaldo.
FRONTEND_URL=http://localhost:5173

# ─── Red Hyperledger Fabric ─────────────────────────────────────────────────
FABRIC_PEER_ENDPOINT=localhost:7051
FABRIC_PEER_HOST_ALIAS=peer0.ficct.edu.bo
FABRIC_MSP_ID=FICCTOrgMSP
FABRIC_CHANNEL=evoting
FABRIC_CHAINCODE=evoting-cc
FABRIC_CA_URL=https://localhost:7054
# La Fabric CA regenera su certificado TLS al recrear su contenedor; en
# desarrollo eso desfasa el tls-cert.pem del disco. Ponlo en true para omitir
# la verificacion (la conexion sigue cifrada). En produccion: false.
CA_TLS_INSECURE=false

# Rutas al material de la red. Si el backend corre dentro del árbol del
# repositorio se deducen solas; declararlas solo al ejecutarlo desde otro sitio.
# FABRIC_NETWORK_PATH=/opt/block/fabric/network
# FABRIC_CRYPTO_PATH=/opt/block/fabric/network/crypto-material

# Chat con IA para reportes (Administrador/Auditor). La clave vive solo en el
# backend, nunca en el navegador. Sin ella, los reportes descargables siguen
# funcionando; solo se desactiva el chat.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
